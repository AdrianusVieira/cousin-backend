{
  "info": {
    "name": "cousin-backend",
    "description": "Manual API testing collection for the cou$in backend. Currently covers the Wallets module; extend as more modules are implemented.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{supabaseJwt}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "supabaseJwt", "value": "" },
    { "key": "walletId", "value": "" }
  ],
  "item": [
    {
      "name": "Wallets",
      "item": [
        {
          "name": "List wallets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/wallets",
              "host": ["{{baseUrl}}"],
              "path": ["wallets"]
            }
          }
        },
        {
          "name": "List active wallets (selector)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/wallets?active=true",
              "host": ["{{baseUrl}}"],
              "path": ["wallets"],
              "query": [{ "key": "active", "value": "true" }]
            }
          }
        },
        {
          "name": "Create wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('walletId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Inter Current Account\",\n  \"description\": \"Main checking account\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/wallets",
              "host": ["{{baseUrl}}"],
              "path": ["wallets"]
            }
          }
        },
        {
          "name": "Get wallet detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "{{walletId}}"]
            }
          }
        },
        {
          "name": "Get wallet detail (custom period)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletId}}?from=2026-03-01&to=2026-06-15",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "{{walletId}}"],
              "query": [
                { "key": "from", "value": "2026-03-01" },
                { "key": "to", "value": "2026-06-15" }
              ]
            }
          }
        },
        {
          "name": "Update wallet name/description",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Inter Current Account\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "{{walletId}}"]
            }
          }
        },
        {
          "name": "Update wallet balance (manual adjustment)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"balance\": \"500.00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "{{walletId}}"]
            }
          }
        },
        {
          "name": "Archive wallet",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletId}}/archive",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "{{walletId}}", "archive"]
            }
          }
        },
        {
          "name": "Unarchive wallet",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletId}}/unarchive",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "{{walletId}}", "unarchive"]
            }
          }
        }
      ]
    }
  ]
}
