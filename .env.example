PORT=3000

# Postgres connection string for the Supabase database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Supabase JWT secret, used to verify Authorization: Bearer tokens
SUPABASE_JWT_SECRET=changeme

# Optional: comma-separated list of allowed CORS origins.
# Leave unset to reflect any origin (fine for local dev / Bearer-token auth).
# CORS_ORIGIN=https://app.example.com,https://staging.example.com
