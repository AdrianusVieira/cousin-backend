PORT=3000

# Postgres connection string for the Supabase database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Supabase JWKS endpoint for verifying ES256 (asymmetric) Bearer tokens.
# Found under Supabase → Settings → API → JWT Signing Keys (Discovery URL).
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Legacy HS256 JWT secret. Optional — kept only to accept already-issued tokens
# during the cutover to ES256. Remove once all clients use asymmetric keys.
SUPABASE_JWT_SECRET=changeme

# Optional: comma-separated list of allowed CORS origins.
# Leave unset to reflect any origin (fine for local dev / Bearer-token auth).
# CORS_ORIGIN=https://app.example.com,https://staging.example.com
